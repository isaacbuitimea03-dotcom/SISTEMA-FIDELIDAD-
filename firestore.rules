rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Specific matches to ensure zero permission friction
    match /customers/{id} {
      allow read, write: if true;
    }
    match /visits/{id} {
      allow read, write: if true;
    }
    match /logs/{id} {
      allow read, write: if true;
    }
    match /config/{id} {
      allow read, write: if true;
    }
    match /surveys/{id} {
      allow read, write: if true;
    }
    match /surveyAnswers/{id} {
      allow read, write: if true;
    }
    match /clerks/{id} {
      allow read, write: if true;
    }
    match /notifications/{id} {
      allow read, write: if true;
    }
    
    // Global safety net
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
